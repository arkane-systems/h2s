@page
@model h2s.Pages.Admin.SettingsModel
@{
    ViewData["Title"] = "Settings";
}

<h1>Settings</h1>

<form method="post" class="mt-3">
    <input asp-for="Settings.Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Settings.Title" class="form-label"></label>
        <input asp-for="Settings.Title" class="form-control" />
        <span asp-validation-for="Settings.Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Settings.Motto" class="form-label"></label>
        <input asp-for="Settings.Motto" class="form-control" />
        <span asp-validation-for="Settings.Motto" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Settings.LocalDomains" class="form-label">Local domains</label>
        <textarea asp-for="Settings.LocalDomains" class="form-control" rows="2"></textarea>
        <div class="form-text">Used to detect external links. Enter one or more domains (comma, semicolon, space, or newline separated), e.g. <code>intranet.local, corp.example.com</code>.</div>
        <span asp-validation-for="Settings.LocalDomains" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Settings.ColorMode" class="form-label">Color mode</label>
        <select asp-for="Settings.ColorMode" class="form-select"
                asp-items="Html.GetEnumSelectList<h2s.Models.ColorMode>()"></select>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
