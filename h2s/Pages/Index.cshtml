@page
@model IndexModel
@{
    ViewData["Title"] = "";
    var adminSectionStarted = false;
    var hasRenderedRegularCategory = false;
}

<section class="home-search-box category-box border">
    <div class="category-box-body">
        <form class="home-search-form" action="https://www.bing.com/search" method="get" role="search">
            <span class="home-search-icon" aria-hidden="true">⌕</span>
            <input type="search"
                   name="q"
                   class="form-control home-search-input"
                   placeholder="Search with Bing"
                   aria-label="Search with Bing"
                   required />
        </form>
    </div>
</section>

<div class="category-grid">
@foreach (var category in Model.Categories)
{
    @if (category.IsAdminCategory && hasRenderedRegularCategory && !adminSectionStarted)
    {
        <div class="category-grid-break" aria-hidden="true"></div>
        adminSectionStarted = true;
    }

    <section class="category-box border @(category.IsAdminCategory ? "category-box-admin" : "")">
        <header class="category-box-header">
            <h2 class="h5 mb-0">@category.Name</h2>
        </header>
        <div class="category-box-body">
            <div class="link-block-list">
                @foreach (var link in category.Links.OrderBy(l => l.Label))
                {
                    var isExternal = Model.IsExternalLink(link.Url);

                    <a class="link-block text-decoration-none text-body" href="@link.Url">
                        @if (isExternal)
                        {
                            <span class="link-external-flag" title="External site" aria-label="External site">External</span>
                        }
                        <div class="link-block-icon-wrap">
                            @if (!string.IsNullOrWhiteSpace(link.IconName))
                            {
                                <img class="link-block-icon" src="@link.GetIconUrl()" alt="@($"{link.Label} icon")" loading="lazy" />
                            }
                            else
                            {
                                <span class="link-block-icon-fallback" aria-hidden="true">•</span>
                            }
                        </div>
                        <div class="link-block-content">
                            <span class="link-block-title">@link.Label</span>
                            @if (!string.IsNullOrWhiteSpace(link.Description))
                            {
                                <span class="link-block-description">@link.Description</span>
                            }
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>

    @if (!category.IsAdminCategory)
    {
        hasRenderedRegularCategory = true;
    }
}
</div>
